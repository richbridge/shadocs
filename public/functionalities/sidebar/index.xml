    <item>
      <title>Simple page</title>
      <link>http://localhost:1313/functionalities/sidebar/simple_page/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/functionalities/sidebar/simple_page/</guid>
      <description>&lt;h1 id=&#39;description&#39; class=&#34;title is-flex is-align-items-center mt-4 is-1&#34;&gt;Description&lt;a href=&#39;#description&#39; class=&#39;anchor&#39;&gt;#&lt;/a&gt;&#xA;&lt;/h1&gt;&lt;hr&gt;&#xA;&lt;p&gt;A content page is defined as follows:&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;&lt;strong&gt;*.md&lt;/strong&gt; page located in a &lt;strong&gt;folder containing at least one section definition page (_index.md)&lt;/strong&gt;&#xA;&lt;div class=&#34;sc-treeview is-overflow-x&#34;&gt;&lt;ul&#xA;      class=&#39;sc-treeview-tree marginless&#39;&gt;&lt;li&#xA;          class=&#34; sc-treeview-coll&#34;&gt;&#xA;          &lt;div class=&#34;sc-treeview-label is-flex is-align-items-center&#34;&gt;&lt;div class=&#34;sc-treeview-icon is-flex is-align-items-center is-justify-content-center sc-treeview-coll-trigger&#34;&gt;&#xA;              &lt;i class=&#34;fa-solid fa-folder fa-fw&#34;&gt;&lt;/i&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;p&gt;Section&lt;/p&gt;&#xA;          &lt;/div&gt;&lt;ul&#xA;      class=&#39;sc-treeview-tree marginless&#39;&gt;&lt;li&#xA;          &gt;&#xA;          &lt;div class=&#34;sc-treeview-label is-flex is-align-items-center&#34;&gt;&lt;div class=&#34;sc-treeview-icon is-flex is-align-items-center is-justify-content-center&#34;&gt;&#xA;              &lt;i class=&#34;fa-solid fa-file fa-fw&#34;&gt;&lt;/i&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;p&gt;_index.md&lt;/p&gt;&#xA;          &lt;/div&gt;&lt;/li&gt;&lt;li&#xA;          &gt;&#xA;          &lt;div class=&#34;sc-treeview-label is-flex is-align-items-center&#34;&gt;&lt;div class=&#34;sc-treeview-icon is-flex is-align-items-center is-justify-content-center&#34;&gt;&#xA;              &lt;i class=&#34;fa-solid fa-file fa-fw&#34;&gt;&lt;/i&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;p&gt;&lt;em&gt;&lt;strong&gt;simple_page.md&lt;/strong&gt;&lt;/em&gt;&lt;/p&gt;&#xA;          &lt;/div&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&#xA;&lt;/li&gt;&#xA;&lt;/ul&gt;</description>
    </item>
    <item>
      <title>Single page with icon</title>
      <link>http://localhost:1313/functionalities/sidebar/icon_simple_page/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/functionalities/sidebar/icon_simple_page/</guid>
      <description>&lt;h1 id=&#39;description&#39; class=&#34;title is-flex is-align-items-center mt-4 is-1&#34;&gt;Description&lt;a href=&#39;#description&#39; class=&#39;anchor&#39;&gt;#&lt;/a&gt;&#xA;&lt;/h1&gt;&lt;hr&gt;&#xA;&lt;p&gt;A content section or page can be identified using an icon from the &lt;a&#xA;  href=&#34;https://fontawesome.com/icons&#34;&#xA;    class=&#34;is-pretty-link&#34;&gt;FontAwesome&lt;/a&#xA;&gt;&#xA; library in order to ease navigation.&lt;/p&gt;&#xA;&lt;p&gt;Two possible parametrization (with the several FontAwesome classes for each parameter value):&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;standard parametrization using the default theme configuration&lt;/li&gt;&#xA;&lt;li&gt;per-page parametrization using the &lt;code&gt;titleIcon&lt;/code&gt; variable in front matter&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h1 id=&#39;standard-parametrization&#39; class=&#34;title is-flex is-align-items-center mt-4 is-1&#34;&gt;Standard parametrization&lt;a href=&#39;#standard-parametrization&#39; class=&#39;anchor&#39;&gt;#&lt;/a&gt;&#xA;&lt;/h1&gt;&lt;hr&gt;&#xA;&lt;div class=&#34;sc-snippet-wrapper is-flex is-flex-wrap-wrap my-4&#34;&gt;&lt;div class=&#34;sc-snippet-container&#34;&gt;&lt;div class=&#34;sc-snippet&#34;&gt;&#xA;        &lt;div class=&#34;sc-snippet-caption&#34;&gt;themeParams.toml&lt;/div&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-toml&#34; data-lang=&#34;toml&#34;&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&#xA;&lt;h1 id=&#39;per-page-parametrization&#39; class=&#34;title is-flex is-align-items-center mt-4 is-1&#34;&gt;Per-page parametrization&lt;a href=&#39;#per-page-parametrization&#39; class=&#39;anchor&#39;&gt;#&lt;/a&gt;&#xA;&lt;/h1&gt;&lt;hr&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;example of the current page:&#xA;&lt;div class=&#34;sc-snippet-wrapper is-flex is-flex-wrap-wrap my-4&#34;&gt;&lt;div class=&#34;sc-snippet-container&#34;&gt;&lt;div class=&#34;sc-snippet&#34;&gt;&#xA;        &lt;div class=&#34;sc-snippet-caption&#34;&gt;page.md&lt;/div&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-md&#34; data-lang=&#34;md&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;---&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;titleIcon: &amp;#34;fa-solid fa-icons&amp;#34;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;---&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/li&gt;&#xA;&lt;/ul&gt;</description>
    </item>
